# Config de producción — copia a .env.production y llena los valores.
# deploy.sh lo sube a la EC2 como /opt/gastly/.env
# Los valores de DATABASE_URL y las URLs salen de: terraform output

# terraform output database_url  (incluye el password de RDS)
DATABASE_URL=postgresql+asyncpg://gastly:PASSWORD@gastly-db.xxxxx.us-east-1.rds.amazonaws.com:5432/gastly?ssl=require

# Genera valores NUEVOS para producción (no reutilices los de dev):
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth — mismo client de dev, pero AGREGA esta redirect URI
# en Google Cloud Console → Credentials → tu OAuth client:
#   https://<terraform output api_url sin https://>/auth/google/callback
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=https://X-X-X-X.sslip.io/auth/google/callback

ANTHROPIC_API_KEY=sk-ant-...

# URL pública del backend (terraform output api_url)
APP_URL=https://X-X-X-X.sslip.io
