# Base de datos PostgreSQL (las tablas se crean solas al arrancar).
# Local:
DATABASE_URL=postgresql+asyncpg://gastly:gastly@localhost:5432/gastly
# Producción en RDS:
# DATABASE_URL=postgresql+asyncpg://gastly:password@gastly-db.xxxxx.us-east-1.rds.amazonaws.com:5432/gastly?ssl=require

# Seguridad JWT
SECRET_KEY=cambia-esto-por-una-clave-segura-de-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cifrado de tokens de Google en la BD (obligatorio en producción).
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Google OAuth (obtener en console.cloud.google.com)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Anthropic Claude API (obtener en console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# URL de la app (para CORS)
APP_URL=http://localhost:8081
